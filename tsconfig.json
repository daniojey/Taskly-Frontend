{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "types": ["vite/client"],   
    "allowJs": true,
    "noImplicitAny": false,
    "noEmit": true,
    "skipLibCheck": true,
  },
  "include": ["src"]
}